# Skopiuj jako .env.local i uzupełnij wartościami z Supabase.
# Project Settings -> API w panelu Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Bazowy URL aplikacji (używany w callbacku OAuth). Lokalnie:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
